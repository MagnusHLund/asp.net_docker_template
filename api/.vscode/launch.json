{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker: Attach to .NET Core",
      "type": "coreclr",
      "request": "attach",
      "processId": "222",
      "sourceFileMap": {
        "/app": "${workspaceFolder}/ChangeMe"
      },
      "pipeTransport": {
        "pipeProgram": "docker",
        "pipeArgs": ["exec", "-i", "change_me_api"],
        "debuggerPath": "/vsdbg/vsdbg",
        "pipeCwd": "${workspaceFolder}",
        "quoteArgs": false
      },
      "args": ["--interpreter=vscode"],
      "requireExactSource": false
    }
  ]
}
